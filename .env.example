# Copy to .env for local dev (Railway: set these in the service Variables tab).

# Port (Railway injects PORT automatically; no need to set it there).
PORT=3000

# Protects the dashboard + management API. If unset, they are OPEN — always set
# this in any deployment that is reachable from the internet.
ADMIN_KEY=change-me-to-a-long-random-string

# Where the SQLite file lives. On Railway, attach a Volume and point this at it
# so captured data survives redeploys, e.g. /data/tracker.db
DB_PATH=./data/tracker.db

# Optional: force the public origin used when building share links / OG tags.
# PUBLIC_URL=https://your-app.up.railway.app
